# EVONIX Kernel Configuration v3.0
# Base: android15-6.6-lts / Linux 6.6.139
# Device: Poco X7 Pro / rodin

# WiFi/BT vendor module compatibility
CONFIG_MODULE_ALLOW_BTF_MISMATCH=y
# CONFIG_MODULE_SIG_PROTECT is not set
# CONFIG_CFG80211 is not set

# EVONIX UFS I/O scheduler support
CONFIG_MQ_IOSCHED_KYBER=y

# EVONIX kernel release branding
CONFIG_LOCALVERSION="-EVONIX-COS-V3.0"
# CONFIG_LOCALVERSION_AUTO is not set
